#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

SERVICE_NAME="netspeedcontrol"
SCRIPT="/usr/bin/netspeedcontrol.sh"
LOG_FILE="/tmp/netspeedcontrol.log"

start_service() {
	: > "$LOG_FILE"
	procd_open_instance
	procd_set_param command /bin/sh -c "while true; do \"$SCRIPT\" apply >>\"$LOG_FILE\" 2>&1; sleep 60; done"
	procd_set_param respawn
	procd_close_instance
}

reload_service() {
	"$SCRIPT" clear >>"$LOG_FILE" 2>&1
	"$SCRIPT" apply >>"$LOG_FILE" 2>&1
}

stop_service() {
	"$SCRIPT" clear >/dev/null 2>&1
}
